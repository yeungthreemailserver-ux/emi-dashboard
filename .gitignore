.venv/
__pycache__/
*.pyc
*.pyo
.env
# API keys — never commit
openai_key.txt
*_key.txt
secrets/
.ipynb_checkpoints/

# Data artifacts (re-ingestable; keep out of git)
data/raw/
data/processed/
# 84MB cached transcripts — re-fetchable via refresh.py counts
data/transcripts/
# regenerable topic-paragraph extracts (build inputs)
data/_topic_*.json
*.db
*.sqlite

# Local tooling / agent config
.claude/

.DS_Store

# local transcript caches (raw text / translations) — not committed, like data/transcripts/
data/transcripts_en/
data/paste/

# News module — regenerable each daily run (raw fetch input + run log); the bundle + history are kept
data/news_raw.json
data/news_last_run.txt
# rolling cluster store — local accumulating state (grows to MB, like a cache/db)
data/news_store.json

# wrangler local cache (account id/build cache) — not for the repo
.wrangler/
