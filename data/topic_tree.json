 "rules": {
  "demand": {
   "axis": "weak <-> hot",
   "favorable": "hot",
   "why": "strong end-demand for what the company sells = more revenue"
  },
  "supply": {
   "axis": "ample/oversupplied <-> tight/sold-out",
   "favorable": "tight-by-demand",
   "why": "tight because demand outruns supply = pricing power (good for the seller); ample/oversupply = weak demand (bad); BUT if the company is itself the bottleneck and loses sales, tight = bad. capex: for equipment vendors customer capex up = THEIR demand up (good)."
  },
  "product": {
   "reads": [
    "demand",
    "supply"
   ],
   "demand_axis": "weak <-> hot",
   "demand_favorable": "hot",
   "supply_axis": "ample <-> tight",
   "supply_favorable": "tight-by-demand",
   "signal": "demand - supply gap: demand>supply => shortage / rising price (bullish); supply>demand => glut / falling price (bearish)"
  },
  "price": {
   "axis": "falling <-> rising",
   "favorable": "rising",
   "why": "rising price = demand >= supply = pricing power for the seller"
  },
  "macro": {
   "axis": "easing <-> worsening",
   "favorable": "easing",
   "why": "external headwind (China export controls / tariffs); worsening = bad"
  }
 }
}